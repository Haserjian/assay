{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "proof_budget_snapshot v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "snapshot_id",
    "timestamp",
    "episode_id",
    "boundary_kind",
    "boundary_refs",
    "required_tier",
    "current_tier",
    "deficit",
    "next_evidence_move",
    "escalation_posture",
    "claim_ids"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "artifact_type": {
      "const": "proof_budget_snapshot"
    },
    "snapshot_id": {
      "type": "string",
      "pattern": "^pbs_[0-9a-f]{12}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "boundary_kind": {
      "type": "string",
      "enum": [
        "checkpoint_decision",
        "guardian_decision",
        "memory_promotion",
        "policy_mutation"
      ]
    },
    "boundary_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "request_id",
        "evaluation_id",
        "decision_receipt_id"
      ],
      "properties": {
        "checkpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "evaluation_id": {
          "type": "string",
          "minLength": 1
        },
        "decision_receipt_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "required_tier": {
      "type": "string",
      "enum": [
        "DRAFT",
        "CHECKED",
        "TOOL_VERIFIED",
        "ADVERSARIAL",
        "CONSTITUTIONAL"
      ]
    },
    "current_tier": {
      "type": "string",
      "enum": [
        "DRAFT",
        "CHECKED",
        "TOOL_VERIFIED",
        "ADVERSARIAL",
        "CONSTITUTIONAL"
      ]
    },
    "deficit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "meets_minimum",
        "gap_refs",
        "blocking_reason_codes"
      ],
      "properties": {
        "meets_minimum": {
          "type": "boolean"
        },
        "gap_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blocking_reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "next_evidence_move": {
      "type": [
        "string",
        "null"
      ]
    },
    "escalation_posture": {
      "type": "string",
      "enum": [
        "sufficient",
        "review_required",
        "blocked",
        "escalate"
      ]
    },
    "claim_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^clm_[0-9a-f]{12}$"
      }
    },
    "contradiction_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ctr_[0-9a-f]{12}$"
      }
    }
  }
}
