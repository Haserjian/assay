{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "claim_assertion v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "claim_id",
    "timestamp",
    "episode_id",
    "claim_text",
    "claim_type",
    "checkable",
    "basis"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "artifact_type": {
      "const": "claim_assertion"
    },
    "claim_id": {
      "type": "string",
      "pattern": "^clm_[0-9a-f]{12}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "claim_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "FACTUAL",
        "CODE_OUTPUT",
        "CONSTRAINT",
        "POLICY",
        "SYNTHESIS"
      ]
    },
    "checkable": {
      "type": "boolean"
    },
    "basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "basis_type",
        "basis_refs",
        "proof_tier_at_assertion"
      ],
      "properties": {
        "basis_type": {
          "type": "string",
          "enum": [
            "extracted",
            "policy_declared",
            "governance_inferred",
            "human_asserted"
          ]
        },
        "basis_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/typed_ref"
          }
        },
        "proof_tier_at_assertion": {
          "type": "string",
          "enum": [
            "DRAFT",
            "CHECKED",
            "TOOL_VERIFIED",
            "ADVERSARIAL",
            "CONSTITUTIONAL"
          ]
        }
      }
    },
    "claim_scope": {
      "type": [
        "string",
        "null"
      ]
    },
    "parent_claim_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^clm_[0-9a-f]{12}$"
    },
    "source_organ": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ccio",
        "loom",
        "agentmesh",
        "assay-toolkit",
        "assay-ledger",
        "puppetlabs",
        null
      ]
    }
  },
  "$defs": {
    "typed_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_type",
        "ref_id",
        "ref_role"
      ],
      "properties": {
        "ref_type": {
          "type": "string",
          "enum": [
            "receipt",
            "claim",
            "attestation",
            "witness_bundle",
            "metric",
            "external"
          ]
        },
        "ref_id": {
          "type": "string",
          "minLength": 1
        },
        "ref_uri": {
          "type": [
            "string",
            "null"
          ]
        },
        "ref_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "ref_role": {
          "type": "string",
          "enum": [
            "supporting",
            "contradicting",
            "contextual",
            "superseded"
          ]
        }
      }
    }
  }
}
